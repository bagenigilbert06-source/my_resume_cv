{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "create-react-app",
  "installCommand": "npx --yes pnpm@10.13.1 --dir gillz_resume_cv install --frozen-lockfile",
  "buildCommand": "npx --yes pnpm@10.13.1 --dir gillz_resume_cv build",
  "outputDirectory": "gillz_resume_cv/build",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
